# =============================================================================
# AI Browsing MCP Stack — Environment Configuration
# Copy this file to .env and fill in your values before starting the stack.
# Never commit the .env file to version control.
# =============================================================================

# ----------------------------------------------------------------------------
# Security
# Generate a strong random key: openssl rand -hex 32
# ----------------------------------------------------------------------------
API_KEY=change_this_to_secure_key

# ----------------------------------------------------------------------------
# Internal service URLs (use Docker service names as hostnames)
# ----------------------------------------------------------------------------
SEARXNG_URL=http://searxng:8080
FIRECRAWL_URL=http://firecrawl-api:3002

# ----------------------------------------------------------------------------
# Search and scraping limits
# ----------------------------------------------------------------------------
# Number of search results to retrieve from SearXNG
RESULT_COUNT=10

# Number of top-ranked URLs to fetch content from
SCRAPE_COUNT=3

# Maximum characters to return per page (prevents huge responses)
MAX_CONTENT_LENGTH=50000

# ----------------------------------------------------------------------------
# Rate limiting
# In-memory, per API key. Replace with Redis-backed limiter for multi-worker.
# ----------------------------------------------------------------------------
RATE_LIMIT_PER_MINUTE=30

# ----------------------------------------------------------------------------
# Logging
# Valid values: DEBUG, INFO, WARNING, ERROR
# ----------------------------------------------------------------------------
LOG_LEVEL=INFO

# ----------------------------------------------------------------------------
# Firecrawl internal configuration (full profile only)
#
# Before running the full profile, clone the Firecrawl source:
#   git clone https://github.com/mendableai/firecrawl.git firecrawl-src
# Then run: docker compose --profile full up -d
#
# The core profile (docker compose --profile core up -d) runs without Firecrawl.
# The /crawl endpoint will return 503 when Firecrawl is not running.
# ----------------------------------------------------------------------------
FIRECRAWL_SRC=./firecrawl-src
FIRECRAWL_REDIS_URL=redis://redis:6379
PLAYWRIGHT_SERVICE_URL=http://playwright-service:3000/scrape

# Firecrawl Postgres (used internally by firecrawl-api)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
